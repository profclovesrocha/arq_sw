<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Qual é a letra</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body> 

<h1>Qual letra começa a palavra?</h1>

<div id="conteudo">
    <p>Carregando pergunta...</p>
</div>

<p id="resultado"></p>

<script>

let respostaCorreta = '';

async function carregarPergunta() {
    const res = await fetch('/pergunta/letra');
    const dados = await res.json();

    respostaCorreta = dados.resposta;

    document.getElementById('conteudo').innerHTML = `
        <h2>${dados.emoji} ${dados.palavra}</h2>
        ${dados.opcoes.map(op => `<button onclick="resposta('${op}')">${op}</button>`).join('')}
    `;
}

function resposta(letra) {
    if (letra === respostaCorreta) {
        document.getElementById('resultado').innerHTML = 'Muito bem! 🎉';

        fetch('/add_pontos', { method: 'POST', credentials: 'same-origin' });

        setTimeout(() => {
            window.location.href = '/home_aluno';
        }, 1000);
    } else {
        document.getElementById('resultado').innerHTML = 'Ops! tente novamente';
    }
}

carregarPergunta();

</script>

</body>
</html>